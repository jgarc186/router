{
  "name": "josegarcia/router",
  "description": "Simple router for PHP, that minics the behavior of the Express router",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "license": "MIT",
  "authors": [
    {
      "name": "jose garcia",
      "email": "jose.garcia051@gmail.com"
    },
    {
      "name": "alejandro foucault",
      "email": "ale@ajfm88.com"
    }
  ],
  "require": {
    "php": ">=7.4.0",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "Garcia\\": "src/Garcia"
    },
    "files": [
      "src/Garcia/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Test\\": "test/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "friendsofphp/php-cs-fixer": "^3.65",
    "squizlabs/php_codesniffer": "^3.7"
  },
    "scripts": {
        "test": "phpunit",
        "fix": "vendor/bin/php-cs-fixer fix ./ --rules=@PSR12",
        "lint": "vendor/bin/phpcs"
    }
}
